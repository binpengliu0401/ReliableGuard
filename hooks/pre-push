#!/bin/bash
# pre-push hook: documentation discipline gate.
#   (1) HARD : reject the push if CHANGELOG.md is not updated in the commits being pushed.
#   (2) WARN : if tracked code changed but README.md did not (judgement call, non-blocking).
#   (3) CHECK: print the documentation checklist and, when run interactively, require an
#              explicit confirmation. Items 3-4 of the checklist live in gitignored
#              CLAUDE.md / memory and cannot be machine-verified from git.
# Install: bash scripts/install-hooks.sh
# Emergency bypass (avoid): git push --no-verify

REPO_ROOT="$(git rev-parse --show-toplevel)"
CODE_REGEX='^(src/|eval/|scripts/|tasks/|ReliableGuard\.py)'

code_changed=0
readme_changed=0

while read -r local_ref local_sha remote_ref remote_sha; do
    if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
        continue  # branch deletion — skip
    fi
    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        range="$local_sha"            # new branch — all reachable commits
    else
        range="$remote_sha..$local_sha"
    fi

    files=$(git log --name-only --pretty=format: "$range" 2>/dev/null | sort -u)

    if ! printf '%s\n' "$files" | grep -q '^CHANGELOG.md$'; then
        echo ""
        echo "Push rejected: CHANGELOG.md was not updated in the commits being pushed ($range)."
        echo "  1. Add an entry under [Unreleased] in CHANGELOG.md"
        echo "  2. Include CHANGELOG.md in the same commit, then push again"
        echo "  Emergency bypass: git push --no-verify"
        echo ""
        exit 1
    fi

    printf '%s\n' "$files" | grep -Eq "$CODE_REGEX" && code_changed=1
    printf '%s\n' "$files" | grep -q '^README.md$' && readme_changed=1
done

if [ "$code_changed" = "1" ] && [ "$readme_changed" = "0" ]; then
    echo ""
    echo "WARNING: tracked code changed but README.md was not updated."
    echo "  If this change adds/moves/removes a file, directory, command, or workflow,"
    echo "  update the README.md structure/usage sections (non-blocking)."
fi

echo ""
echo "================ Pre-push documentation checklist ================"
echo "  1. CHANGELOG.md  - entry under [Unreleased]            (HARD-gated above)"
echo "  2. README.md     - updated if a file/dir/command/workflow changed"
echo "  3. CLAUDE.md + memory/ - framework decisions recorded  (local-only)"
echo "  4. CLAUDE.md 'Code Task Checklist' - done/pending updated (local-only)"
echo "  details: docs/push_checklist.md"
echo "=================================================================="

# Only enforce the confirmation when /dev/tty is genuinely usable. Probing it by an
# actual write+read (errors suppressed) is more reliable than `[ -r /dev/tty ]`, which is
# true even when the device node exists but has no controlling terminal (IDE/CI pushes).
if printf "Confirm the documentation checklist is satisfied? [y/N] " 2>/dev/null >/dev/tty \
   && IFS= read -r reply 2>/dev/null </dev/tty; then
    case "$reply" in
        y|Y|yes|YES) echo "Checklist confirmed. Proceeding with push." ;;
        *)
            echo "Push aborted: documentation checklist not confirmed."
            echo "  (re-run after updating docs, or 'git push --no-verify' to bypass)"
            exit 1
            ;;
    esac
else
    echo "(non-interactive shell - checklist shown as a reminder, not enforced.)"
fi

exit 0
